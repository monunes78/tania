# ─── PostgreSQL / Supabase ────────────────────────────
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mude-esta-senha-forte

# Supabase Studio — chaves JWT (manter consistentes)
# Gere em: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7b9PrgYNsrSFHQKzBm6lAGDy24p46WdxPsA
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ─── Autenticação AD/LDAP ─────────────────────────────
LDAP_SERVER=ldap://srv-ad.tanac.com.br
LDAP_DOMAIN=tanac.com.br
LDAP_BASE_DN=DC=tanac,DC=com,DC=br
LDAP_BIND_USER=svc_tania@tanac.com.br
LDAP_BIND_PASSWORD=

# ─── JWT (tokens da aplicação TanIA) ─────────────────
JWT_SECRET=mude-para-uma-chave-forte-de-256-bits
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_HOURS=24

# ─── Criptografia (API keys no banco) ────────────────
ENCRYPTION_KEY=mude-para-chave-aes256-base64

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO ───────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=tania_admin
MINIO_SECRET_KEY=mude-esta-senha
MINIO_BUCKET=tania-documents
MINIO_SECURE=false

# ─── LiteLLM Proxy ───────────────────────────────────
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=mude-esta-chave

# ─── LLM Padrão (OpenRouter para testes) ─────────────
OPENROUTER_API_KEY=sk-or-

# ─── n8n ──────────────────────────────────────────────
N8N_BASE_URL=http://n8n.tanac.local:5678
N8N_WEBHOOK_SECRET=mude-este-secret
N8N_API_KEY=

# ─── Microsoft Teams (App Registration Azure AD) ──────
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# ─── E-mail (SMTP) ───────────────────────────────────
SMTP_HOST=smtp.tanac.com.br
SMTP_PORT=587
SMTP_USER=tania@tanac.com.br
SMTP_PASSWORD=
SMTP_FROM=TanIA <tania@tanac.com.br>

# ─── Frontend ─────────────────────────────────────────
NEXTAUTH_URL=https://tania.tanac.com.br
NEXTAUTH_SECRET=mude-este-secret
NEXT_PUBLIC_API_URL=https://tania.tanac.com.br

# ─── Ambiente ─────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
